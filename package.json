{
  "name": "@mixxtor/adonisjs-pusher",
  "version": "2.0.0-next.1",
  "description": "AdonisJS provider for Pusher real-time messaging",
  "engines": {
    "node": ">=24"
  },
  "main": "build/index.js",
  "type": "module",
  "files": [
    "build",
    "!build/bin",
    "!build/tests"
  ],
  "exports": {
    ".": "./build/index.js",
    "./types": "./build/src/types/index.js",
    "./services/main": "./build/services/main.js",
    "./provider": "./build/providers/pusher_provider.js"
  },
  "scripts": {
    "clean": "del-cli build",
    "copy:templates": "copyfiles \"stubs/**/*.stub\" build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "quick:test": "node --import=@poppinss/ts-exec --enable-source-maps bin/test.ts",
    "pretest": "npm run lint",
    "test": "c8 npm run quick:test",
    "prebuild": "npm run lint && npm run clean",
    "build": "tsc",
    "postbuild": "npm run copy:templates",
    "release": "release-it",
    "release:patch": "release-it patch",
    "release:minor": "release-it minor",
    "release:major": "release-it major",
    "release:next": "release-it --preRelease=next --npm.tag=next",
    "release:beta": "release-it --preRelease=beta",
    "release:alpha": "release-it --preRelease=alpha",
    "release:dry": "release-it --dry-run",
    "version": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "adonisjs",
    "pusher",
    "realtime",
    "websockets",
    "provider"
  ],
  "author": "Mixxtor",
  "license": "MIT",
  "devDependencies": {
    "@adonisjs/assembler": "^8.4.0",
    "@adonisjs/core": "^7.3.4",
    "@adonisjs/eslint-config": "^3.1.0",
    "@adonisjs/prettier-config": "^1.5.0",
    "@adonisjs/tsconfig": "^2.0.0",
    "@japa/assert": "^4.2.0",
    "@japa/runner": "^5.3.0",
    "@release-it/conventional-changelog": "^11.0.1",
    "@types/node": "^26.1.0",
    "c8": "^11.0.0",
    "copyfiles": "^2.4.1",
    "del-cli": "^7.0.0",
    "eslint": "^10.6.0",
    "prettier": "^3.9.4",
    "release-it": "^20.2.1",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "@adonisjs/core": "^7.0.0"
  },
  "dependencies": {
    "pusher": "^5.3.4"
  },
  "homepage": "https://github.com/mixxtor/adonisjs-pusher#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mixxtor/adonisjs-pusher.git"
  },
  "bugs": {
    "url": "https://github.com/mixxtor/adonisjs-pusher/issues"
  },
  "publishConfig": {
    "access": "public",
    "tag": "latest"
  },
  "release-it": {
    "git": {
      "commitMessage": "chore: release v${version}",
      "tagName": "v${version}",
      "requireCleanWorkingDir": false,
      "requireUpstream": false,
      "push": true,
      "pushArgs": [
        "--follow-tags"
      ]
    },
    "github": {
      "release": true,
      "releaseName": "Release v${version}",
      "releaseNotes": null,
      "autoGenerate": true,
      "draft": false,
      "preRelease": false
    },
    "npm": {
      "publish": true,
      "publishPath": ".",
      "access": "public",
      "otp": false
    },
    "hooks": {
      "before:init": [
        "npm run lint",
        "npm run typecheck"
      ],
      "after:bump": [
        "npm run build"
      ],
      "before:release": [
        "npm test"
      ],
      "after:release": [
        "echo 🎉 Release ${version} completed successfully!"
      ]
    },
    "plugins": {
      "@release-it/conventional-changelog": {
        "preset": {
          "name": "conventionalcommits",
          "types": [
            {
              "type": "feat",
              "section": "✨ Features"
            },
            {
              "type": "fix",
              "section": "🐛 Bug Fixes"
            },
            {
              "type": "perf",
              "section": "⚡ Performance Improvements"
            },
            {
              "type": "refactor",
              "section": "♻️ Code Refactoring"
            },
            {
              "type": "docs",
              "section": "📚 Documentation"
            },
            {
              "type": "test",
              "section": "🧪 Tests"
            },
            {
              "type": "build",
              "section": "🏗️ Build System"
            },
            {
              "type": "ci",
              "section": "👷 CI/CD"
            },
            {
              "type": "chore",
              "section": "🔧 Maintenance"
            }
          ]
        },
        "infile": "CHANGELOG.md",
        "header": "# Changelog\n\nAll notable changes to this project will be documented in this file.\n\n"
      }
    }
  },
  "c8": {
    "reporter": [
      "text",
      "html"
    ],
    "exclude": [
      "tests/**"
    ]
  },
  "prettier": "@adonisjs/prettier-config"
}
